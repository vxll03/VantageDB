    "@pinia/nuxt": "^0.11.3",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-virtual": "^3.13.18",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "nuxt": "^4.1.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.28",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bg-dev/nuxt-naiveui": "^2.0.0",
    "@iconify/vue": "^5.0.0",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/eslint-config": "^1.15.1",
    "@types/dagre": "^0.7.53",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.7.0",
    "ofetch": "^1.5.1",
    "prettier": "^3.7.4",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vue-tsc": "^3.1.5"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
